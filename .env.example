# 数据库配置
DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/app?sslmode=disable
# Linux Do 授权配置
LINUXDO_CLIENT_ID=your-client-id
LINUXDO_CLIENT_SECRET=your-client-secret
LINUXDO_REDIRECT_URI=http://127.0.0.1:8080/auth/callback
# JWT 签名配置
JWT_SECRET=replace-with-a-long-random-secret
# 监听端口
LISTEN_ADDR=:8080
# 签到阈值配置
QUOTA_THRESHOLD=10000000
QUOTA_INCREMENT_MIN=10000000
QUOTA_INCREMENT_MAX=10000000
# PoW 计算量证明配置
CHECKIN_POW_ENABLED=true
CHECKIN_POW_DIFFICULTY=18
CHECKIN_POW_TTL_SECONDS=300
# Turnstile 验证码配置
CHECKIN_TURNSTILE_ENABLED=false
CHECKIN_TURNSTILE_SITE_KEY=
CHECKIN_TURNSTILE_SECRET_KEY=
